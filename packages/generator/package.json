{
  "name": "@staticforge/generator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/build-pages.test.ts",
    "validate:input": "tsx src/validate-input.cli.ts",
    "preview:pages": "tsx src/preview-pages.cli.ts",
    "generate": "tsx src/generate-pages.cli.ts --locale de"
  },
  "dependencies": {
    "@staticforge/schemas": "workspace:*",
    "@staticforge/core": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
